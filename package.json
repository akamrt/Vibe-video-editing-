{
  "name": "vibecut-ai",
  "description": "AI-powered video editor with Python tracking, Gemini AI, and timeline editing",
  "author": "VibeCut AI",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/server.cjs",
    "electron:dev": "concurrently \"vite\" \"node server/server.cjs\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:pack": "vite build && electron-builder --dir",
    "electron:compile": "tsc -p electron/tsconfig.json"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@google/genai": "^1.37.0",
    "@jitsi/rnnoise-wasm": "^0.2.1",
    "@remotion/player": "^4.0.419",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "google-trends-api": "^4.9.2",
    "multer": "^2.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remotion": "^4.0.419",
    "webm-muxer": "^5.1.4",
    "youtube-transcript": "^1.2.1",
    "youtube-transcript-api": "^3.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  }
}
