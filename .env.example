# Required: Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: Alternative AI model keys (for short generation)
# KIMI_API_KEY=your_kimi_key
# OPENAI_API_KEY=your_openai_key
# MINIMAX_API_KEY=your_minimax_key

# Supabase (required for shared database & auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Server config
PORT=3001
NODE_ENV=development
